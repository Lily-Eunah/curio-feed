# Neon PostgreSQL Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>/curio_feed?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-user>
SPRING_DATASOURCE_PASSWORD=<neon-password>

# CORS allowed origins (comma separated)
# Phase 1: Include your temporary Quick Tunnel URL (https://*.trycloudflare.com)
# Phase 2: Replace with your actual domain (e.g. https://curiofeed.com,https://www.curiofeed.com)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://curio-feed.pages.dev

# Admin API token — required in the X-Admin-Token header for /api/admin/** endpoints.
# Generate a strong random value (e.g. `openssl rand -hex 32`). Without it the admin
# API is fail-closed (returns 503). Never commit the real value.
ADMIN_API_TOKEN=<your-strong-random-admin-token>

# Article generation: Gemini Free Tier API
LLM_PROVIDER=gemini
GEMINI_API_KEY=<your-gemini-api-key>

# TTS: Google Cloud Text-to-Speech
TTS_API_KEY=<your-tts-api-key>

# Grafana Cloud Remote Write
GRAFANA_REMOTE_WRITE_URL=https://prometheus-prod-xxx.grafana.net/api/v1/push
GRAFANA_REMOTE_WRITE_USERNAME=1234567
GRAFANA_REMOTE_WRITE_PASSWORD=glc_xxxxxxxxxxxxxx
