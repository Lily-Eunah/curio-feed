# Neon PostgreSQL Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>/curio_feed?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-user>
SPRING_DATASOURCE_PASSWORD=<neon-password>

# CORS allowed origins (comma separated)
# Phase 1: Include your temporary Quick Tunnel URL (https://*.trycloudflare.com)
# Phase 2: Replace with your actual domain (e.g. https://curiofeed.com,https://www.curiofeed.com)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://curio-feed.pages.dev

# External API Keys (Required for GPT/Gemini pipelines and TTS services)
LLM_API_KEY=
TTS_API_KEY=
